  <h1>人狼ゲーム 完全プレイ版</h1>
  <div class="note">
    4〜15人対応 / プレイヤー名変更可 / 配役自由 / Kahoot風デモ対応
  </div>
</header>

<main>

<section id="home" class="card">
  <h2>モード選択</h2>

  <button onclick="openMode('local')">
    1つの端末を回して遊ぶ
  </button>

  <button class="purple" onclick="openMode('online')">
    各端末参加風デモ
  </button>

  <p class="note">
    ※本物のオンライン同期ではありません。<br>
    GitHub Pagesだけで動作するデモ版です。
  </p>
</section>

<section id="setup" class="hidden">

  <div class="card">

    <h2 id="setupTitle">ゲーム設定</h2>

    <label>人数 (4〜15人)</label>

    <input
      id="playerCount"
      type="number"
      min="4"
      max="15"
      value="6"
    >

    <button onclick="applyPlayerCount()">
      人数を反映
    </button>

    <div id="playerInputs"></div>

  </div>

  <div class="card">

    <h2>役職人数</h2>

    <div id="roleInputs" class="grid"></div>

    <button class="green" onclick="autoRoles()">
      おすすめ配役
    </button>

    <button onclick="startGame()">
      ゲーム開始
    </button>

    <button class="secondary" onclick="goHome()">
      戻る
    </button>

  </div>

</section>

<section id="reveal" class="hidden">

  <div class="card">

    <h2 id="revealName"></h2>

    <div id="roleBox" class="roleBox hidden"></div>

    <button id="showBtn" onclick="showRole()">
      役職を見る
    </button>

    <button
      id="nextBtn"
      class="hidden"
      onclick="nextReveal()"
    >
      次の人へ
    </button>

  </div>

</section>

<section id="game" class="hidden">

  <div class="card">

    <h2>ゲーム進行</h2>

    <div class="big" id="phaseText"></div>

    <p class="note" id="phaseGuide"></p>

    <button onclick="nextPhase()">
      次のフェーズ
    </button>

    <button
      class="secondary"
      onclick="toggleGM()"
    >
      GM情報 表示/非表示
    </button>

    <button
      class="danger"
      onclick="resetAll()"
    >
      最初から
    </button>

  </div>

  <div class="card">

    <h2>生存状況</h2>

    <div id="aliveList"></div>

  </div>

  <div id="gmPanel" class="card hidden">

    <h2>GM用情報</h2>

    <div id="gmRoles"></div>

    <hr>

    <select id="target"></select>

    <button
      class="danger"
      onclick="killPlayer('追放')"
    >
      追放
    </button>

    <button
      class="danger"
      onclick="killPlayer('襲撃')"
    >
      襲撃
    </button>

    <button
      class="green"
      onclick="revivePlayer()"
    >
      生存に戻す
    </button>

    <hr>

    <h3>ログ</h3>

    <div id="logBox" class="log"></div>

  </div>

</section>

<section id="online" class="hidden">

  <div class="card">

    <h2>各端末参加風デモ</h2>

    <button onclick="createRoom()">
      部屋を作る
    </button>

    <div id="roomArea" class="hidden">

      <p class="big">
        部屋コード：
        <span id="roomCode"></span>
      </p>

      <input
        id="joinName"
        placeholder="参加者名"
      >

      <button onclick="joinRoom()">
        参加者追加
      </button>

      <div id="demoPlayers"></div>

      <button
        class="green"
        onclick="useDemoPlayers()"
      >
        この参加者で開始
      </button>

    </div>

    <button
      class="secondary"
      onclick="goHome()"
    >
      戻る
    </button>

  </div>

