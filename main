<script>

const ROLES = [
  "市民",
  "占い師",
  "霊媒師",
  "騎士",
  "人狼",
  "狂人",
  "狂信者"
];

const DESC = {
  "市民":"特殊能力なし。",
  "占い師":"夜に1人を占う。",
  "霊媒師":"追放者を確認。",
  "騎士":"1人を守る。",
  "人狼":"夜に襲撃。",
  "狂人":"人狼陣営。",
  "狂信者":"人狼が分かる。"
};

const phases = [
  {
    name:"昼",
    guide:"議論してください。"
  },
  {
    name:"投票",
    guide:"追放者を決めます。"
  },
  {
    name:"夜",
    guide:"役職行動をしてください。"
  },
  {
    name:"朝",
    guide:"結果発表。"
  }
];

let players = [];
let assignments = [];
let revealIndex = 0;
let day = 1;
let phaseIndex = 0;
let logs = [];
let demoPlayers = [];

function $(id){
  return document.getElementById(id);
}

function hideAll(){
  [
    "home",
    "setup",
    "reveal",
    "game",
    "online"
  ].forEach(id=>{
    $(id).classList.add("hidden");
  });
}

function goHome(){
  hideAll();
  $("home").classList.remove("hidden");
}

function openMode(mode){

  hideAll();

  if(mode === "local"){

    $("setup").classList.remove("hidden");

    applyPlayerCount();

  }else{

    $("online").classList.remove("hidden");

  }
}

function applyPlayerCount(){

  let count = Number(
    $("playerCount").value
  );

  if(isNaN(count)){
    count = 4;
  }

  count = Math.max(
    4,
    Math.min(15,count)
  );

  $("playerCount").value = count;

  const box = $("playerInputs");

  box.innerHTML = "";

  for(let i=0;i<count;i++){

    const div = document.createElement("div");

    div.className = "row";

    div.innerHTML = `
      <input
        id="player${i}"
        value="プレイヤー${i+1}"
      >
    `;

    box.appendChild(div);

  }

  makeRoleInputs();

}

function recommendedRoles(n){

  const r = {
    "市民":0,
    "占い師":1,
    "霊媒師":0,
    "騎士":0,
    "人狼":1,
    "狂人":0,
    "狂信者":0
  };

  if(n >= 5){
    r["騎士"] = 1;
  }

  if(n >= 7){
    r["霊媒師"] = 1;
  }

  if(n >= 8){
    r["人狼"] = 2;
  }

  if(n >= 9){
    r["狂人"] = 1;
  }

  if(n >= 12){
    r["人狼"] = 3;
  }

  let used = 0;

  Object.values(r).forEach(v=>{
    used += v;
  });

  r["市民"] = n - used;

  return r;
}

function makeRoleInputs(){

  const count = Number(
    $("playerCount").value
  );

  const roles = recommendedRoles(count);

  const box = $("roleInputs");

  box.innerHTML = "";

  ROLES.forEach(role=>{

    const div = document.createElement("div");

    div.innerHTML = `
      <label>${role}</label>

      <input
        class="roleCount"
        data-role="${role}"
        type="number"
        min="0"
        max="15"
        value="${roles[role] || 0}"
      >
    `;

    box.appendChild(div);

  });

}

function autoRoles(){
  makeRoleInputs();
}

function collectRoles(){

  const pool = [];

  document
    .querySelectorAll(".roleCount")
    .forEach(input=>{

      const role = input.dataset.role;

      const num = Number(input.value);

      for(let i=0;i<num;i++){
        pool.push(role);
      }

    });

  return pool;

}

function shuffle(arr){

  const a = [...arr];

  for(let i=a.length-1;i>0;i--){

    const j = Math.floor(
      Math.random()*(i+1)
    );

    [a[i],a[j]]=[a[j],a[i]];

  }

  return a;

}

function startGame(){

  const count = Number(
    $("playerCount").value
  );

  players = [];

  for(let i=0;i<count;i++){

    players.push({
      name:
        $("player"+i).value.trim()
        || ("プレイヤー"+(i+1)),
      alive:true
    });

  }

  const rolePool = collectRoles();

  if(rolePool.length !== count){

    alert(
      "役職人数の合計を"+
      count+
      "人にしてください"
    );

    return;

  }

  if(!rolePool.includes("人狼")){

    alert("人狼を1人以上入れてください");

    return;

  }

  const shuffled = shuffle(rolePool);

  assignments = players.map((p,i)=>({
    ...p,
    role:shuffled[i]
  }));

  revealIndex = 0;

  day = 1;

  phaseIndex = 0;

  logs = ["ゲーム開始"];

  hideAll();

  $("reveal").classList.remove("hidden");

  setupReveal();

}

function setupReveal(){

  const p = assignments[revealIndex];

  $("revealName").textContent =
    p.name + " さん";

  $("roleBox").classList.add("hidden");

  $("showBtn").classList.remove("hidden");

  $("nextBtn").classList.add("hidden");

}

function showRole(){

  const p = assignments[revealIndex];

  let text =
    p.role +
    "\n" +
    DESC[p.role];

  if(
    p.role === "人狼" ||
    p.role === "狂信者"
  ){

    const wolves = assignments
      .filter(x=>x.role==="人狼")
      .map(x=>x.name)
      .join("、");

    text +=
      "\n\n人狼：" +
      wolves;

  }

  $("roleBox").textContent = text;

  $("roleBox").classList.remove("hidden");

  $("showBtn").classList.add("hidden");

  $("nextBtn").classList.remove("hidden");

}

function nextReveal(){

  revealIndex++;

  if(revealIndex >= assignments.length){

    hideAll();

    $("game").classList.remove("hidden");

    renderGame();

    return;

  }

  setupReveal();

}

function renderGame(){

  const ph = phases[phaseIndex];

  $("phaseText").textContent =
    day + "日目 " + ph.name;

  $("phaseGuide").textContent =
    ph.guide;

  $("aliveList").innerHTML =
    assignments.map((p,i)=>`
      <div class="
        playerCard
        ${p.alive ? "" : "dead"}
      ">
        ${i+1}. ${p.name}
        ：
        ${p.alive ? "生存" : "死亡"}
      </div>
    `).join("");

  $("gmRoles").innerHTML =
    assignments.map(p=>`
      <span class="
        badge
        ${p.alive ? "" : "dead"}
      ">
        ${p.name}
        ：
        ${p.role}
      </span>
    `).join("");

  $("target").innerHTML =
    assignments.map((p,i)=>`
      <option value="${i}">
        ${p.name}
      </option>
    `).join("");

  $("logBox").textContent =
    logs.join("\n");

  checkWinner();

}

function nextPhase(){

  phaseIndex++;

  if(phaseIndex >= phases.length){

    phaseIndex = 0;

    day++;

  }

  renderGame();

}

function toggleGM(){

  $("gmPanel")
    .classList
    .toggle("hidden");

}

function killPlayer(type){

  const i = Number(
    $("target").value
  );

  assignments[i].alive = false;

  logs.push(
    day +
    "日目：" +
    assignments[i].name +
    " が" +
    type +
    "された"
  );

  renderGame();

}

function revivePlayer(){

  const i = Number(
    $("target").value
  );

  assignments[i].alive = true;

  logs.push(
    assignments[i].name +
    " を生存に戻した"
  );

  renderGame();

}

function checkWinner(){

  const alive =
    assignments.filter(p=>p.alive);

  const wolves =
    alive.filter(
      p=>p.role==="人狼"
    ).length;

  const villagers =
    alive.length - wolves;

  if(wolves === 0){

    $("phaseGuide").textContent +=
      " 市民陣営の勝利";

  }else if(wolves >= villagers){

    $("phaseGuide").textContent +=
      " 人狼陣営の勝利";

  }

}

function resetAll(){

  players = [];

  assignments = [];

  logs = [];

  goHome();

}

function createRoom(){

  $("roomArea")
    .classList
    .remove("hidden");

  $("roomCode").textContent =
    Math.random()
      .toString(36)
      .substring(2,7)
      .toUpperCase();

  demoPlayers = [];

  renderDemoPlayers();

}

function joinRoom(){

  const name =
    $("joinName")
      .value
      .trim();

  if(!name){

    alert("名前を入力");

    return;

  }

  if(demoPlayers.length >= 15){

    alert("最大15人");

    return;

  }

  demoPlayers.push(name);

  $("joinName").value = "";

  renderDemoPlayers();

}

function renderDemoPlayers(){

  $("demoPlayers").innerHTML =
    demoPlayers.map((p,i)=>`
      <span class="badge">
        ${i+1}. ${p}
      </span>
    `).join("");

}

function useDemoPlayers(){

  if(demoPlayers.length < 4){

    alert("4人以上必要");

    return;

  }

  hideAll();

  $("setup")
    .classList
    .remove("hidden");

  $("playerCount").value =
    demoPlayers.length;

  $("playerInputs").innerHTML =
    "";

  demoPlayers.forEach((name,i)=>{

    const div =
      document.createElement("div");

    div.className = "row";

    div.innerHTML = `
      <input
        id="player${i}"
        value="${name}"
      >
    `;

    $("playerInputs")
      .appendChild(div);

  });

  makeRoleInputs();

}

goHome();

</script>

</body>
</html>
