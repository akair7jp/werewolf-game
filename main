from pathlib import Path

html = r'''<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>人狼ゲーム 完全プレイ版</title>
<style>
*{box-sizing:border-box}
body{margin:0;font-family:system-ui,sans-serif;background:linear-gradient(135deg,#111827,#020617);color:#fff}
header{padding:18px;background:#020617cc;position:sticky;top:0;z-index:10}
main{padding:16px;max-width:900px;margin:auto}
.card{background:#1f2937;border:1px solid #374151;border-radius:18px;padding:16px;margin:14px 0}
button,input,select{width:100%;padding:13px;margin:7px 0;border-radius:12px;border:1px solid #4b5563;font-size:16px}
input,select{background:#111827;color:white}
button{background:#2563eb;color:white;font-weight:700;cursor:pointer}
button.secondary{background:#4b5563}
button.danger{background:#dc2626}
button.green{background:#16a34a}
button.purple{background:#7c3aed}
.hidden{display:none!important}
.grid{display:grid;grid-template-columns:1fr;gap:10px}
@media(min-width:700px){.grid{grid-template-columns:1fr 1fr}}
.row{display:flex;gap:8px}
.note{color:#cbd5e1;font-size:14px;line-height:1.7}
.big{font-size:22px;font-weight:800}
.badge{display:inline-block;background:#374151;padding:7px 11px;border-radius:999px;margin:4px}
.roleBox{white-space:pre-line;text-align:center;background:#111827;border:2px solid #60a5fa;border-radius:18px;padding:24px;font-size:26px;font-weight:800;margin:14px 0}
.playerCard{background:#111827;border:1px solid #374151;padding:12px;border-radius:14px;margin:8px 0}
.dead{opacity:.45;text-decoration:line-through}
.log{background:#020617;padding:12px;border-radius:12px;max-height:230px;overflow:auto;white-space:pre-line;font-size:14px}
hr{border:0;border-top:1px solid #374151;margin:14px 0}
</style>
</head>
<body>
<header>
  <h1>人狼ゲーム 完全プレイ版</h1>
  <div class="note">4〜15人 / 役職自由 / 交互プレイ / 各端末参加風デモ</div>
</header>

<main>
<section id="screenHome" class="card">
  <h2>モードを選択</h2>
  <button onclick="openMode('local')">1つのデバイスを交互に回す</button>
  <button class="purple" onclick="openMode('online')">各ユーザが自分のデバイスで参加する風デモ</button>
  <p class="note">※本物の別端末同期にはFirebaseなどが必要です。この版では1つのHTML内で流れを確認できます。</p>
</section>

<section id="setupScreen" class="hidden">
  <div class="card">
    <h2 id="setupTitle">ゲーム設定</h2>
    <label>人数 4〜15人</label>
    <input id="playerCount" type="number" min="4" max="15" value="6">
    <button onclick="applyPlayerCount()">人数を反映</button>
    <div id="playerInputs"></div>
  </div>

  <div class="card">
    <h2>役職人数</h2>
    <p class="note">役職の合計人数がプレイヤー人数と同じになるようにしてください。</p>
    <div id="roleInputs" class="grid"></div>
    <button class="green" onclick="autoBalanceRoles()">おすすめ配役にする</button>
    <button onclick="startGame()">ゲーム開始</button>
    <button class="secondary" onclick="goHome()">戻る</button>
  </div>
</section>

<section id="revealScreen" class="hidden">
  <div class="card">
    <h2 id="revealName"></h2>
    <p class="note">本人に端末を渡してから押してください。</p>
    <div id="roleReveal" class="roleBox hidden"></div>
    <button id="showRoleBtn" onclick="showRole()">役職を見る</button>
    <button id="hideAndNextBtn" class="hidden" onclick="nextReveal()">隠して次の人へ</button>
  </div>
</section>

<section id="gameScreen" class="hidden">
  <div class="card">
    <h2>ゲーム進行</h2>
    <div class="big" id="phaseText"></div>
    <p id="phaseGuide" class="note"></p>
    <button onclick="nextPhase()">次のフェーズへ</button>
    <button class="secondary" onclick="toggleGM()">GM用情報 表示/非表示</button>
    <button class="danger" onclick="resetAll()">最初から</button>
  </div>

  <div class="card">
    <h2>生存状況</h2>
    <div id="aliveList"></div>
  </div>

  <div id="gmPanel" class="card hidden">
    <h2>GM用情報</h2>
    <div id="gmRoles"></div>
    <hr>
    <h3>処刑・襲撃</h3>
    <select id="targetSelect"></select>
    <button class="danger" onclick="killSelected('追放')">追放する</button>
    <button class="danger" onclick="killSelected('襲撃')">襲撃された</button>
    <button class="green" onclick="reviveSelected()">生存に戻す</button>
    <hr>
    <h3>ログ</h3>
    <div id="logBox" class="log"></div>
  </div>
</section>

<section id="onlineDemoScreen" class="hidden">
  <div class="card">
    <h2>各端末参加風デモ</h2>
    <button onclick="createDemoRoom()">ホストとして部屋を作る</button>
    <div id="roomArea" class="hidden">
      <p class="big">部屋コード：<span id="roomCode"></span></p>
      <input id="demoJoinName" placeholder="参加者名">
      <button onclick="demoJoin()">参加者を追加</button>
      <div id="demoPlayers"></div>
      <button class="green" onclick="useDemoPlayers()">この参加者でゲーム設定へ</button>
    </div>
    <button class="secondary" onclick="goHome()">戻る</button>
  </div>
</section>
</main>

<script>
const ROLES=["市民","占い師","霊媒師","騎士","人狼","狂人","狂信者"];

const DESC={
"市民":"特殊能力なし。議論と推理で人狼を探す。",
"占い師":"夜に1人を占い、人狼かどうか確認する。",
"霊媒師":"追放された人が人狼かどうか確認する。",
"騎士":"夜に1人を守る。",
"人狼":"夜に人狼同士で相談し、1人を襲撃する。",
"狂人":"人狼陣営だが、人狼が誰かは分からない。",
"狂信者":"人狼陣営で、人狼が誰か分かる。"
};

let players=[];
let assignments=[];
let revealIndex=0;
let day=1;
let phaseIndex=0;
let logs=[];
let demoPlayers=[];

const phases=[
{name:"昼",guide:"全員で議論してください。"},
{name:"投票",guide:"追放する人を決めてください。"},
{name:"夜",guide:"役職者と人狼が行動してください。"},
{name:"朝",guide:"夜の結果を発表してください。"}
];

function $(id){return document.getElementById(id)}
function esc(s){return String(s).replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#039;"}[m]))}

function hideAll(){
 ["screenHome","setupScreen","revealScreen","gameScreen","onlineDemoScreen"].forEach(id=>$(id).classList.add("hidden"));
}

function goHome(){
 hideAll();
 $("screenHome").classList.remove("hidden");
}

function openMode(m){
 hideAll();
 if(m==="local"){
   $("setupTitle").textContent="交互プレイ：ゲーム設定";
   $("setupScreen").classList.remove("hidden");
   applyPlayerCount();
 }else{
   $("onlineDemoScreen").classList.remove("hidden");
 }
}

function getCount(){
 let count=Number($("playerCount").value);
 if(isNaN(count)) count=4;
 count=Math.max(4,Math.min(15,count));
 $("playerCount").value=count;
 return count;
}

function applyPlayerCount(){
 const count=getCount();
 const old=[];
 document.querySelectorAll("#playerInputs input").forEach(i=>old.push(i.value));

 $("playerInputs").innerHTML="";
 for(let i=0;i<count;i++){
   const div=document.createElement("div");
   div.className="row";
   const input=document.createElement("input");
   input.id="player"+i;
   input.placeholder="プレイヤー名";
   input.value=old[i]||"プレイヤー"+(i+1);
   div.appendChild(input);
   $("playerInputs").appendChild(div);
 }
 makeRoleInputs(true);
}

function recommendedRoles(n){
 const r={"市民":0,"占い師":1,"霊媒師":0,"騎士":0,"人狼":1,"狂人":0,"狂信者":0};
 if(n>=5) r["騎士"]=1;
 if(n>=7) r["霊媒師"]=1;
 if(n>=8) r["人狼"]=2;
 if(n>=9) r["狂人"]=1;
 if(n>=12) r["人狼"]=3;
 if(n>=14){r["狂人"]=0;r["狂信者"]=1}
 let used=Object.values(r).reduce((a,b)=>a+b,0);
 r["市民"]=Math.max(0,n-used);
 return r;
}

function makeRoleInputs(useDefault=false){
 const count=getCount();
 const current={};
 document.querySelectorAll(".roleCount").forEach(i=>current[i.dataset.role]=Number(i.value)||0);
 const defaults=recommendedRoles(count);

 $("roleInputs").innerHTML="";
 ROLES.forEach(role=>{
   const wrap=document.createElement("div");
   const label=document.createElement("label");
   label.textContent=role;
   const input=document.createElement("input");
   input.className="roleCount";
   input.dataset.role=role;
   input.type="number";
   input.min=0;
   input.max=15;
   input.value=useDefault ? defaults[role] : (current[role] ?? defaults[role]);
   wrap.appendChild(label);
   wrap.appendChild(input);
   $("roleInputs").appendChild(wrap);
 });
}

function autoBalanceRoles(){
 makeRoleInputs(true);
}

function collectRoles(){
 const pool=[];
 document.querySelectorAll(".roleCount").forEach(input=>{
   const role=input.dataset.role;
   const num=Math.max(0,Number(input.value)||0);
   for(let i=0;i<num;i++) pool.push(role);
 });
 return pool;
}

function shuffle(arr){
 const a=[...arr];
 for(let i=a.length-1;i>0;i--){
   const j=Math.floor(Math.random()*(i+1));
   [a[i],a[j]]=[a[j],a[i]];
 }
 return a;
}

function startGame(){
 const count=getCount();
 players=[];
 for(let i=0;i<count;i++){
   const input=$("player"+i);
   players.push({name:(input?.value.trim()||"プレイヤー"+(i+1)),alive:true});
 }

 const rolePool=collectRoles();
 if(rolePool.length!==count){
   alert("役職の合計が "+rolePool.length+" 人です。プレイヤー人数 "+count+" 人に合わせてください。");
   return;
 }
 if(!rolePool.includes("人狼")){
   alert("人狼を最低1人入れてください。");
   return;
 }

 const shuffled=shuffle(rolePool);
 assignments=players.map((p,i)=>({...p,role:shuffled[i]}));
 revealIndex=0;
 day=1;
 phaseIndex=0;
 logs=["ゲーム開始"];

 hideAll();
 $("revealScreen").classList.remove("hidden");
 setupReveal();
}

function setupReveal(){
 const p=assignments[revealIndex];
 $("revealName").textContent=p.name+" さんの番です";
 $("roleReveal").classList.add("hidden");
 $("roleReveal").textContent="";
 $("showRoleBtn").classList.remove("hidden");
 $("hideAndNextBtn").classList.add("hidden");
}

function showRole(){
 const p=assignments[revealIndex];
 let text=p.role+"\n"+DESC[p.role];

 if(p.role==="人狼"||p.role==="狂信者"){
   const wolves=assignments.filter(x=>x.role==="人狼").map(x=>x.name).join("、");
   text+="\n\n人狼："+wolves;
 }

 $("roleReveal").textContent=text;
 $("roleReveal").classList.remove("hidden");
 $("showRoleBtn").classList.add("hidden");
 $("hideAndNextBtn").classList.remove("hidden");
}

function nextReveal(){
 revealIndex++;
 if(revealIndex>=assignments.length){
   hideAll();
   $("gameScreen").classList.remove("hidden");
   renderGame();
   return;
 }
 setupReveal();
}

function renderGame(){
 const ph=phases[phaseIndex];
 $("phaseText").textContent=day+"日目 "+ph.name;
 $("phaseGuide").textContent=ph.guide;

 $("aliveList").innerHTML=assignments.map((p,i)=>`
   <div class="playerCard ${p.alive?"":"dead"}">
     ${i+1}. ${esc(p.name)}：${p.alive?"生存":"死亡"}
   </div>
 `).join("");

 $("gmRoles").innerHTML=assignments.map(p=>`
   <span class="badge ${p.alive?"":"dead"}">${esc(p.name)}：${esc(p.role)}</span>
 `).join("");

 $("targetSelect").innerHTML=assignments.map((p,i)=>`
   <option value="${i}">${esc(p.name)} / ${p.alive?"生存":"死亡"} / ${esc(p.role)}</option>
 `).join("");

 $("logBox").textContent=logs.join("\n");
 checkWinner();
}

function nextPhase(){
 phaseIndex++;
 if(phaseIndex>=phases.length){
   phaseIndex=0;
   day++;
 }
 renderGame();
}

function toggleGM(){
 $("gmPanel").classList.toggle("hidden");
}

function killSelected(type){
 const i=Number($("targetSelect").value);
 if(!assignments[i]) return;
 if(!assignments[i].alive){
   alert("このプレイヤーはすでに死亡しています。");
   return;
 }
 assignments[i].alive=false;
 logs.push(day+"日目："+assignments[i].name+" が"+type+"されました。");
 renderGame();
}

function reviveSelected(){
 const i=Number($("targetSelect").value);
 if(!assignments[i]) return;
 if(assignments[i].alive){
   alert("このプレイヤーはすでに生存しています。");
   return;
 }
 assignments[i].alive=true;
 logs.push(assignments[i].name+" を生存に戻しました。");
 renderGame();
}

function checkWinner(){
 const alive=assignments.filter(p=>p.alive);
 const wolves=alive.filter(p=>p.role==="人狼").length;
 const villagers=alive.length-wolves;

 if(wolves===0){
   $("phaseGuide").textContent+="　勝敗：市民陣営の勝利です。";
 }else if(wolves>=villagers){
   $("phaseGuide").textContent+="　勝敗：人狼陣営の勝利です。";
 }
}

function resetAll(){
 players=[];
 assignments=[];
 revealIndex=0;
 day=1;
 phaseIndex=0;
 logs=[];
 demoPlayers=[];
 $("gmPanel").classList.add("hidden");
 goHome();
}

function createDemoRoom(){
 $("roomArea").classList.remove("hidden");
 $("roomCode").textContent=Math.random().toString(36).substring(2,7).toUpperCase();
 demoPlayers=[];
 renderDemoPlayers();
}

function demoJoin(){
 const name=$("demoJoinName").value.trim();
 if(!name){
   alert("参加者名を入力してください。");
   return;
 }
 if(demoPlayers.length>=15){
   alert("最大15人です。");
   return;
 }
 demoPlayers.push(name);
 $("demoJoinName").value="";
 renderDemoPlayers();
}

function renderDemoPlayers(){
 $("demoPlayers").innerHTML=demoPlayers.map((p,i)=>`
   <span class="badge">${i+1}. ${esc(p)}</span>
 `).join("");
}

function useDemoPlayers(){
 if(demoPlayers.length<4){
   alert("4人以上追加してください。");
   return;
 }
 hideAll();
 $("setupTitle").textContent="各端末参加風デモ：ゲーム設定";
 $("setupScreen").classList.remove("hidden");
 $("playerCount").value=demoPlayers.length;
 $("playerInputs").innerHTML="";

 demoPlayers.forEach((name,i)=>{
   const div=document.createElement("div");
   div.className="row";
   const input=document.createElement("input");
   input.id="player"+i;
   input.placeholder="プレイヤー名";
   input.value=name;
   div.appendChild(input);
   $("playerInputs").appendChild(div);
 });
 makeRoleInputs(true);
}

goHome();
</script>
</body>
</html>
'''

path = Path("/mnt/data/werewolf_full_playable_fixed.html")
path.write_text(html, encoding="utf-8")
print(path)
